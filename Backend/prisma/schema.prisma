// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  CONFIRMED
  TENTATIVE
  CANCELLED
  RESCHEDULED
}

enum OverrideType {
  CLOSED
  CUSTOM_HOURS
}

enum BookingTokenPurpose {
  CONFIRMATION
  CANCEL
  RESCHEDULE
}

model User {
  id              String                 @id @default(cuid()) @map("_id")
  username        String                 @unique
  email           String                 @unique
  fullName        String
  avatar          String                 @default("")
  defaultTimezone String                 @default("UTC")
  password        String
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  eventTypes      EventType[]
  schedules       AvailabilitySchedule[]
  overrides       AvailabilityOverride[]
  bookings        Booking[]
}

model EventType {
  id                     String               @id @default(cuid()) @map("_id")
  hostUserId             String
  title                  String
  description            String               @default("")
  slug                   String
  durationMinutes        Int
  durationOptions        Int[]                @default([])
  sortOrder              Int                  @default(0)
  hidden                 Boolean              @default(false)
  active                 Boolean              @default(true)
  color                  String               @default("#292929")
  schedulingType         String?
  requiresConfirmation   Boolean              @default(false)
  seatsPerTimeSlot       Int?
  metadata               Json?
  availabilityScheduleId String
  bufferBeforeMinutes    Int                  @default(0)
  bufferAfterMinutes     Int                  @default(0)
  slotIntervalMinutes    Int                  @default(15)
  minimumNoticeMinutes   Int                  @default(0)
  bookingWindowDays      Int                  @default(60)
  bookingQuestions       Json                 @default("[]")
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  host                   User                 @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  availabilitySchedule   AvailabilitySchedule @relation(fields: [availabilityScheduleId], references: [id], onDelete: Restrict)
  bookings               Booking[]

  @@unique([hostUserId, slug])
  @@index([hostUserId, sortOrder])
}

model AvailabilitySchedule {
  id         String                 @id @default(cuid()) @map("_id")
  hostUserId String
  name       String
  timezone   String
  isDefault  Boolean                @default(false)
  weeklyRules Json                  @default("{}")
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  host       User                   @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  eventTypes EventType[]
  overrides  AvailabilityOverride[]

  @@index([hostUserId, isDefault])
}

model AvailabilityOverride {
  id         String               @id @default(cuid()) @map("_id")
  hostUserId String
  scheduleId String
  date       String
  type       OverrideType
  intervals  Json                 @default("[]")
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  host       User                 @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  schedule   AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, date])
  @@index([scheduleId])
}

model Booking {
  id                      String        @id @default(cuid()) @map("_id")
  hostUserId              String
  eventTypeId             String
  status                  BookingStatus @default(CONFIRMED)
  startAt                 DateTime
  endAt                   DateTime
  blockedStartAt          DateTime
  blockedEndAt            DateTime
  bookerName              String
  bookerEmail             String
  guestEmails             String[]      @default([])
  answers                 Json          @default("[]")
  notes                   String        @default("")
  meetingWhereType        String        @default("cal-video")
  meetingWhereDetail      String        @default("")
  cancellationReason      String        @default("")
  rescheduledFromBookingId String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  host                    User          @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  eventType               EventType     @relation(fields: [eventTypeId], references: [id], onDelete: Restrict)
  bookingTokens           BookingToken[]

  @@index([hostUserId, startAt, status])
  @@index([hostUserId, blockedStartAt, blockedEndAt, status])
}

model BookingToken {
  id        String              @id @default(cuid()) @map("_id")
  bookingId String
  tokenHash String              @unique
  purpose   BookingTokenPurpose
  expiresAt DateTime
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  booking   Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, purpose])
  @@index([expiresAt])
}
