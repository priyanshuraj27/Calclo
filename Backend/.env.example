PORT=8000
# Allowed origins for CORS requests
CORS_ORIGIN=*

# Database connection string (path /DB_NAME is appended in code from constant.js)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>
MONGODB_PASSWORD=<your_password>

# Single host (no JWT) — must match seeded user
DEFAULT_HOST_USERNAME=priyanshu

# Optional seed overrides (see npm run seed)
SEED_HOST_EMAIL=
SEED_HOST_FULL_NAME=
SEED_HOST_PASSWORD=
SEED_TIMEZONE=Asia/Kolkata

# Cloudinary (optional; not used by scheduling API)
CLOUDINARY_CLOUD_NAME=<your_cloud_name>
CLOUDINARY_API_KEY=<your_api_key>
CLOUDINARY_API_SECRET=<your_api_secret>
